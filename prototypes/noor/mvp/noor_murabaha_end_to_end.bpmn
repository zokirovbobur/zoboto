<?xml version="1.0" encoding="UTF-8"?>
<bpmn2:definitions xmlns:bpmn2="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:bioc="http://bpmn.io/schema/bpmn/biocolor/1.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:color="http://www.omg.org/spec/BPMN/non-normative/color/1.0" id="Definitions_1" targetNamespace="http://bpmn.io/schema/bpmn" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.16.0">
  <bpmn2:collaboration id="Collaboration_Noor">
    <bpmn2:participant id="Participant_Noor" name="Noor Ecosystem Murabaha Process" processRef="Process_NoorMurabaha" />
    <bpmn2:participant id="Participant_Prescoring" name="PHASE 1: Prescoring" processRef="Process_Prescoring" />
    <bpmn2:messageFlow id="Flow_1qfoj4a" sourceRef="EndEvent_LimitDisplayed_Process_Prescoring" targetRef="StartEvent_RetailerOpen_Process_NoorMurabaha" />
    <bpmn2:textAnnotation id="Annotation_SCCP_1_Process_NoorMurabaha">
      <bpmn2:text>SCCP: Bank purchases goods before selling. No cash loan to client.</bpmn2:text>
    </bpmn2:textAnnotation>
    <bpmn2:association id="Association_Annotation_1_Process_NoorMurabaha" sourceRef="Annotation_SCCP_1_Process_NoorMurabaha" targetRef="Task_TransferFunds_Process_NoorMurabaha" />
    <bpmn2:textAnnotation id="Annotation_SCCP_2_Process_NoorMurabaha">
      <bpmn2:text>SCCP: Driver acts as Bank's Wakil. Bank takes possession &amp; risk (Qabd).</bpmn2:text>
    </bpmn2:textAnnotation>
    <bpmn2:association id="Association_Annotation_2_Process_NoorMurabaha" sourceRef="Annotation_SCCP_2_Process_NoorMurabaha" targetRef="Task_ConfirmQabd_Process_NoorMurabaha" />
    <bpmn2:textAnnotation id="Annotation_SCCP_3_Process_NoorMurabaha">
      <bpmn2:text>SCCP: Murabaha contract signed. Debt obligation starts now.</bpmn2:text>
    </bpmn2:textAnnotation>
    <bpmn2:association id="Association_Annotation_3_Process_NoorMurabaha" sourceRef="Annotation_SCCP_3_Process_NoorMurabaha" targetRef="Task_GenerateContract_Process_NoorMurabaha" />
  </bpmn2:collaboration>
  <bpmn2:process id="Process_NoorMurabaha" name="Noor Ecosystem Murabaha Process" isExecutable="true">
    <bpmn2:laneSet id="LaneSet_1">
      <bpmn2:lane id="Lane_Sharma" name="Shariah Compliance / Audit">
        <bpmn2:flowNodeRef>Task_AuditCompliance_Process_NoorMurabaha</bpmn2:flowNodeRef>
      </bpmn2:lane>
      <bpmn2:lane id="Lane_Core" name="Noor Core / Islamic Neobank">
        <bpmn2:flowNodeRef>Task_CalculateLimit_Process_NoorMurabaha</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>Gateway_LimitSufficient_Process_NoorMurabaha</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>Task_ReserveLimit_Process_NoorMurabaha</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>Task_InitiatePayment_Process_NoorMurabaha</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>Task_RecordBankTitle_Process_NoorMurabaha</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>Task_GenerateContract_Process_NoorMurabaha</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>Task_UpdateDebt_Process_NoorMurabaha</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>Gateway_11w898d</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>Gateway_DebtCleared_Process_NoorMurabaha</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>EndEvent_MurabahaRepaid_Process_NoorMurabaha</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>Task_HandleOverdue_Process_NoorMurabaha</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>Activity_1kj9p1z</bpmn2:flowNodeRef>
      </bpmn2:lane>
      <bpmn2:lane id="Lane_Paynet" name="Paynet / Xolis">
        <bpmn2:flowNodeRef>Task_TransferFunds_Process_NoorMurabaha</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>Task_SplitPayments_Process_NoorMurabaha</bpmn2:flowNodeRef>
      </bpmn2:lane>
      <bpmn2:lane id="Lane_Driver" name="Driver / Damas Labo">
        <bpmn2:flowNodeRef>Task_PickupInspect_Process_NoorMurabaha</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>Gateway_QualityCheck_Process_NoorMurabaha</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>Task_ConfirmQabd_Process_NoorMurabaha</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>Task_DeliverGoods_Process_NoorMurabaha</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>EndEvent_Dispute_Process_NoorMurabaha</bpmn2:flowNodeRef>
      </bpmn2:lane>
      <bpmn2:lane id="Lane_Wholesaler" name="Wholesaler / Food City">
        <bpmn2:flowNodeRef>Task_CheckStock_Process_NoorMurabaha</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>Gateway_StockAvailable_Process_NoorMurabaha</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>Task_PackGoods_Process_NoorMurabaha</bpmn2:flowNodeRef>
      </bpmn2:lane>
      <bpmn2:lane id="Lane_Marketplace" name="Noor Marketplace App">
        <bpmn2:flowNodeRef>Task_ShowLimit_Process_NoorMurabaha</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>Task_CreateOrder_Process_NoorMurabaha</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>Task_ShowTerms_Process_NoorMurabaha</bpmn2:flowNodeRef>
      </bpmn2:lane>
      <bpmn2:lane id="Lane_Retailer" name="Retail Trader / Buyer">
        <bpmn2:flowNodeRef>StartEvent_RetailerOpen_Process_NoorMurabaha</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>Task_SelectProduct_Process_NoorMurabaha</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>EndEvent_OrderCancelled_Process_NoorMurabaha</bpmn2:flowNodeRef>
        <bpmn2:flowNodeRef>Task_AcceptReceipt_Process_NoorMurabaha</bpmn2:flowNodeRef>
      </bpmn2:lane>
      <bpmn2:lane id="Lane_0fzsi6z" name="AKSLabs">
        <bpmn2:flowNodeRef>Activity_1t4vggv</bpmn2:flowNodeRef>
      </bpmn2:lane>
    </bpmn2:laneSet>
    <bpmn2:startEvent id="StartEvent_RetailerOpen_Process_NoorMurabaha" name="Retailer Opens App">
      <bpmn2:outgoing>Flow_1_Process_NoorMurabaha</bpmn2:outgoing>
    </bpmn2:startEvent>
    <bpmn2:task id="Task_ShowLimit_Process_NoorMurabaha" name="Display Financing Limit">
      <bpmn2:incoming>Flow_1_Process_NoorMurabaha</bpmn2:incoming>
      <bpmn2:outgoing>Flow_2_Process_NoorMurabaha</bpmn2:outgoing>
      <bpmn2:dataOutputAssociation id="DataAssociation_Limit_Process_NoorMurabaha">
        <bpmn2:targetRef>DataObjectReference_Limit_Process_NoorMurabaha</bpmn2:targetRef>
      </bpmn2:dataOutputAssociation>
    </bpmn2:task>
    <bpmn2:task id="Task_SelectProduct_Process_NoorMurabaha" name="Select Goods &#38; Terms">
      <bpmn2:incoming>Flow_2_Process_NoorMurabaha</bpmn2:incoming>
      <bpmn2:outgoing>Flow_3_Process_NoorMurabaha</bpmn2:outgoing>
    </bpmn2:task>
    <bpmn2:task id="Task_CreateOrder_Process_NoorMurabaha" name="Create Purchase Order">
      <bpmn2:incoming>Flow_3_Process_NoorMurabaha</bpmn2:incoming>
      <bpmn2:outgoing>Flow_4_Process_NoorMurabaha</bpmn2:outgoing>
      <bpmn2:dataOutputAssociation id="DataAssociation_Order_Process_NoorMurabaha">
        <bpmn2:targetRef>DataObjectReference_Order_Process_NoorMurabaha</bpmn2:targetRef>
      </bpmn2:dataOutputAssociation>
    </bpmn2:task>
    <bpmn2:task id="Task_CalculateLimit_Process_NoorMurabaha" name="Assess Financing Limit">
      <bpmn2:incoming>Flow_4_Process_NoorMurabaha</bpmn2:incoming>
      <bpmn2:outgoing>Flow_5_Process_NoorMurabaha</bpmn2:outgoing>
    </bpmn2:task>
    <bpmn2:exclusiveGateway id="Gateway_LimitSufficient_Process_NoorMurabaha" name="Limit Sufficient?" default="Flow_6_Process_NoorMurabaha">
      <bpmn2:incoming>Flow_5_Process_NoorMurabaha</bpmn2:incoming>
      <bpmn2:outgoing>Flow_6_Process_NoorMurabaha</bpmn2:outgoing>
      <bpmn2:outgoing>Flow_7_Process_NoorMurabaha</bpmn2:outgoing>
    </bpmn2:exclusiveGateway>
    <bpmn2:task id="Task_ReserveLimit_Process_NoorMurabaha" name="Reserve Funds">
      <bpmn2:incoming>Flow_7_Process_NoorMurabaha</bpmn2:incoming>
      <bpmn2:outgoing>Flow_8_Process_NoorMurabaha</bpmn2:outgoing>
    </bpmn2:task>
    <bpmn2:task id="Task_CheckStock_Process_NoorMurabaha" name="Confirm Stock Availability">
      <bpmn2:incoming>Flow_8_Process_NoorMurabaha</bpmn2:incoming>
      <bpmn2:outgoing>Flow_9_Process_NoorMurabaha</bpmn2:outgoing>
    </bpmn2:task>
    <bpmn2:exclusiveGateway id="Gateway_StockAvailable_Process_NoorMurabaha" name="In Stock?" default="Flow_10_Process_NoorMurabaha">
      <bpmn2:incoming>Flow_9_Process_NoorMurabaha</bpmn2:incoming>
      <bpmn2:outgoing>Flow_10_Process_NoorMurabaha</bpmn2:outgoing>
      <bpmn2:outgoing>Flow_11_Process_NoorMurabaha</bpmn2:outgoing>
    </bpmn2:exclusiveGateway>
    <bpmn2:task id="Task_InitiatePayment_Process_NoorMurabaha" name="Initiate Bank Purchase">
      <bpmn2:incoming>Flow_12_Process_NoorMurabaha</bpmn2:incoming>
      <bpmn2:outgoing>Flow_13_Process_NoorMurabaha</bpmn2:outgoing>
    </bpmn2:task>
    <bpmn2:task id="Task_TransferFunds_Process_NoorMurabaha" name="Transfer Funds to Wholesaler">
      <bpmn2:incoming>Flow_13_Process_NoorMurabaha</bpmn2:incoming>
      <bpmn2:outgoing>Flow_14_Process_NoorMurabaha</bpmn2:outgoing>
      <bpmn2:dataOutputAssociation id="DataAssociation_Payment_Process_NoorMurabaha">
        <bpmn2:targetRef>DataObjectReference_BankConf_Process_NoorMurabaha</bpmn2:targetRef>
      </bpmn2:dataOutputAssociation>
    </bpmn2:task>
    <bpmn2:task id="Task_RecordBankTitle_Process_NoorMurabaha" name="Record Bank Ownership (Qabd Legal)">
      <bpmn2:incoming>Flow_14_Process_NoorMurabaha</bpmn2:incoming>
      <bpmn2:outgoing>Flow_15_Process_NoorMurabaha</bpmn2:outgoing>
    </bpmn2:task>
    <bpmn2:task id="Task_PickupInspect_Process_NoorMurabaha" name="Pickup &#38; Inspect Goods">
      <bpmn2:incoming>Flow_15_Process_NoorMurabaha</bpmn2:incoming>
      <bpmn2:outgoing>Flow_16_Process_NoorMurabaha</bpmn2:outgoing>
    </bpmn2:task>
    <bpmn2:exclusiveGateway id="Gateway_QualityCheck_Process_NoorMurabaha" name="Goods OK?" default="Flow_17_Process_NoorMurabaha">
      <bpmn2:incoming>Flow_16_Process_NoorMurabaha</bpmn2:incoming>
      <bpmn2:outgoing>Flow_17_Process_NoorMurabaha</bpmn2:outgoing>
      <bpmn2:outgoing>Flow_18_Process_NoorMurabaha</bpmn2:outgoing>
    </bpmn2:exclusiveGateway>
    <bpmn2:task id="Task_ConfirmQabd_Process_NoorMurabaha" name="Confirm Physical Qabd (Wakil)">
      <bpmn2:incoming>Flow_18_Process_NoorMurabaha</bpmn2:incoming>
      <bpmn2:outgoing>Flow_19_Process_NoorMurabaha</bpmn2:outgoing>
      <bpmn2:dataOutputAssociation id="DataAssociation_QabdConfirm_Process_NoorMurabaha">
        <bpmn2:targetRef>DataObjectReference_Qabd_Process_NoorMurabaha</bpmn2:targetRef>
      </bpmn2:dataOutputAssociation>
    </bpmn2:task>
    <bpmn2:task id="Task_DeliverGoods_Process_NoorMurabaha" name="Deliver to Retailer">
      <bpmn2:incoming>Flow_19_Process_NoorMurabaha</bpmn2:incoming>
      <bpmn2:outgoing>Flow_20_Process_NoorMurabaha</bpmn2:outgoing>
    </bpmn2:task>
    <bpmn2:task id="Task_ShowTerms_Process_NoorMurabaha" name="Show Murabaha Terms">
      <bpmn2:incoming>Flow_21_Process_NoorMurabaha</bpmn2:incoming>
      <bpmn2:outgoing>Flow_22_Process_NoorMurabaha</bpmn2:outgoing>
    </bpmn2:task>
    <bpmn2:task id="Task_GenerateContract_Process_NoorMurabaha" name="Execute Murabaha Contract">
      <bpmn2:incoming>Flow_22_Process_NoorMurabaha</bpmn2:incoming>
      <bpmn2:outgoing>Flow_23_Process_NoorMurabaha</bpmn2:outgoing>
      <bpmn2:dataOutputAssociation id="DataAssociation_Contract_Process_NoorMurabaha">
        <bpmn2:targetRef>DataObjectReference_Contract_Process_NoorMurabaha</bpmn2:targetRef>
      </bpmn2:dataOutputAssociation>
    </bpmn2:task>
    <bpmn2:task id="Task_AuditCompliance_Process_NoorMurabaha" name="Validate Compliance Points">
      <bpmn2:incoming>Flow_23_Process_NoorMurabaha</bpmn2:incoming>
      <bpmn2:outgoing>Flow_24_Process_NoorMurabaha</bpmn2:outgoing>
    </bpmn2:task>
    <bpmn2:task id="Task_SplitPayments_Process_NoorMurabaha" name="Split Income (Repay 20% vs Balance 80%)">
      <bpmn2:incoming>Flow_24_Process_NoorMurabaha</bpmn2:incoming>
      <bpmn2:incoming>Flow_29_Process_NoorMurabaha</bpmn2:incoming>
      <bpmn2:outgoing>Flow_25_Process_NoorMurabaha</bpmn2:outgoing>
    </bpmn2:task>
    <bpmn2:endEvent id="EndEvent_Dispute_Process_NoorMurabaha" name="Dispute / Damaged">
      <bpmn2:incoming>Flow_17_Process_NoorMurabaha</bpmn2:incoming>
    </bpmn2:endEvent>
    <bpmn2:dataObjectReference id="DataObjectReference_Limit_Process_NoorMurabaha" name="Financing Limit" dataObjectRef="DataObject_Limit_Process_NoorMurabaha" />
    <bpmn2:dataObject id="DataObject_Limit_Process_NoorMurabaha" name="Financing Limit" />
    <bpmn2:dataObjectReference id="DataObjectReference_Order_Process_NoorMurabaha" name="Purchase Order" dataObjectRef="DataObject_Order_Process_NoorMurabaha" />
    <bpmn2:dataObject id="DataObject_Order_Process_NoorMurabaha" name="Purchase Order" />
    <bpmn2:dataObjectReference id="DataObjectReference_BankConf_Process_NoorMurabaha" name="Bank Purchase Confirmation" dataObjectRef="DataObject_BankConf_Process_NoorMurabaha" />
    <bpmn2:dataObject id="DataObject_BankConf_Process_NoorMurabaha" name="Bank Purchase Confirmation">
      <bpmn2:documentation>Legal proof bank purchased goods from wholesaler</bpmn2:documentation>
    </bpmn2:dataObject>
    <bpmn2:dataObjectReference id="DataObjectReference_Qabd_Process_NoorMurabaha" name="Qabd Confirmation" dataObjectRef="DataObject_Qabd_Process_NoorMurabaha" />
    <bpmn2:dataObject id="DataObject_Qabd_Process_NoorMurabaha" name="Qabd Confirmation" />
    <bpmn2:dataObjectReference id="DataObjectReference_Contract_Process_NoorMurabaha" name="Murabaha Contract" dataObjectRef="DataObject_Contract_Process_NoorMurabaha" />
    <bpmn2:dataObject id="DataObject_Contract_Process_NoorMurabaha" name="Murabaha Contract" />
    <bpmn2:task id="Task_PackGoods_Process_NoorMurabaha" name="Prepare Shipment">
      <bpmn2:incoming>Flow_11_Process_NoorMurabaha</bpmn2:incoming>
      <bpmn2:outgoing>Flow_12_Process_NoorMurabaha</bpmn2:outgoing>
    </bpmn2:task>
    <bpmn2:endEvent id="EndEvent_OrderCancelled_Process_NoorMurabaha" name="Order Cancelled">
      <bpmn2:incoming>Flow_6_Process_NoorMurabaha</bpmn2:incoming>
      <bpmn2:incoming>Flow_10_Process_NoorMurabaha</bpmn2:incoming>
    </bpmn2:endEvent>
    <bpmn2:task id="Task_AcceptReceipt_Process_NoorMurabaha" name="Scan QR &#38; Accept">
      <bpmn2:incoming>Flow_20_Process_NoorMurabaha</bpmn2:incoming>
      <bpmn2:outgoing>Flow_21_Process_NoorMurabaha</bpmn2:outgoing>
    </bpmn2:task>
    <bpmn2:task id="Task_UpdateDebt_Process_NoorMurabaha" name="Apply Payment to Debt">
      <bpmn2:incoming>Flow_25_Process_NoorMurabaha</bpmn2:incoming>
      <bpmn2:outgoing>Flow_188tuec</bpmn2:outgoing>
    </bpmn2:task>
    <bpmn2:task id="Activity_1t4vggv" name="Monitor the daily transaction volume via Merchant QR">
      <bpmn2:incoming>Flow_188tuec</bpmn2:incoming>
      <bpmn2:outgoing>Flow_0lvnbj1</bpmn2:outgoing>
    </bpmn2:task>
    <bpmn2:exclusiveGateway id="Gateway_11w898d" name="Abnormal drop in cashless revenue? (possible shift to cash)">
      <bpmn2:incoming>Flow_0lvnbj1</bpmn2:incoming>
      <bpmn2:outgoing>Flow_0j8sxa4</bpmn2:outgoing>
    </bpmn2:exclusiveGateway>
    <bpmn2:exclusiveGateway id="Gateway_DebtCleared_Process_NoorMurabaha" name="Debt Cleared?" default="Flow_28_Process_NoorMurabaha">
      <bpmn2:incoming>Flow_0j8sxa4</bpmn2:incoming>
      <bpmn2:outgoing>Flow_27_Process_NoorMurabaha</bpmn2:outgoing>
      <bpmn2:outgoing>Flow_28_Process_NoorMurabaha</bpmn2:outgoing>
    </bpmn2:exclusiveGateway>
    <bpmn2:endEvent id="EndEvent_MurabahaRepaid_Process_NoorMurabaha" name="Murabaha Fully Repaid">
      <bpmn2:incoming>Flow_27_Process_NoorMurabaha</bpmn2:incoming>
    </bpmn2:endEvent>
    <bpmn2:task id="Task_HandleOverdue_Process_NoorMurabaha" name="Block access to new purchases — Default status">
      <bpmn2:incoming>Flow_28_Process_NoorMurabaha</bpmn2:incoming>
      <bpmn2:outgoing>Flow_0wj7x9w</bpmn2:outgoing>
    </bpmn2:task>
    <bpmn2:task id="Activity_1kj9p1z" name="Start Overdue Process (Charity Penalty)">
      <bpmn2:incoming>Flow_0wj7x9w</bpmn2:incoming>
      <bpmn2:outgoing>Flow_29_Process_NoorMurabaha</bpmn2:outgoing>
    </bpmn2:task>
    <bpmn2:sequenceFlow id="Flow_1_Process_NoorMurabaha" sourceRef="StartEvent_RetailerOpen_Process_NoorMurabaha" targetRef="Task_ShowLimit_Process_NoorMurabaha" />
    <bpmn2:sequenceFlow id="Flow_2_Process_NoorMurabaha" sourceRef="Task_ShowLimit_Process_NoorMurabaha" targetRef="Task_SelectProduct_Process_NoorMurabaha" />
    <bpmn2:sequenceFlow id="Flow_3_Process_NoorMurabaha" sourceRef="Task_SelectProduct_Process_NoorMurabaha" targetRef="Task_CreateOrder_Process_NoorMurabaha" />
    <bpmn2:sequenceFlow id="Flow_4_Process_NoorMurabaha" sourceRef="Task_CreateOrder_Process_NoorMurabaha" targetRef="Task_CalculateLimit_Process_NoorMurabaha" />
    <bpmn2:sequenceFlow id="Flow_5_Process_NoorMurabaha" sourceRef="Task_CalculateLimit_Process_NoorMurabaha" targetRef="Gateway_LimitSufficient_Process_NoorMurabaha" />
    <bpmn2:sequenceFlow id="Flow_6_Process_NoorMurabaha" name="No" sourceRef="Gateway_LimitSufficient_Process_NoorMurabaha" targetRef="EndEvent_OrderCancelled_Process_NoorMurabaha" />
    <bpmn2:sequenceFlow id="Flow_7_Process_NoorMurabaha" name="Yes" sourceRef="Gateway_LimitSufficient_Process_NoorMurabaha" targetRef="Task_ReserveLimit_Process_NoorMurabaha" />
    <bpmn2:sequenceFlow id="Flow_8_Process_NoorMurabaha" sourceRef="Task_ReserveLimit_Process_NoorMurabaha" targetRef="Task_CheckStock_Process_NoorMurabaha" />
    <bpmn2:sequenceFlow id="Flow_9_Process_NoorMurabaha" sourceRef="Task_CheckStock_Process_NoorMurabaha" targetRef="Gateway_StockAvailable_Process_NoorMurabaha" />
    <bpmn2:sequenceFlow id="Flow_10_Process_NoorMurabaha" name="No" sourceRef="Gateway_StockAvailable_Process_NoorMurabaha" targetRef="EndEvent_OrderCancelled_Process_NoorMurabaha" />
    <bpmn2:sequenceFlow id="Flow_11_Process_NoorMurabaha" name="Yes" sourceRef="Gateway_StockAvailable_Process_NoorMurabaha" targetRef="Task_PackGoods_Process_NoorMurabaha" />
    <bpmn2:sequenceFlow id="Flow_12_Process_NoorMurabaha" sourceRef="Task_PackGoods_Process_NoorMurabaha" targetRef="Task_InitiatePayment_Process_NoorMurabaha" />
    <bpmn2:sequenceFlow id="Flow_13_Process_NoorMurabaha" sourceRef="Task_InitiatePayment_Process_NoorMurabaha" targetRef="Task_TransferFunds_Process_NoorMurabaha" />
    <bpmn2:sequenceFlow id="Flow_14_Process_NoorMurabaha" sourceRef="Task_TransferFunds_Process_NoorMurabaha" targetRef="Task_RecordBankTitle_Process_NoorMurabaha" />
    <bpmn2:sequenceFlow id="Flow_15_Process_NoorMurabaha" sourceRef="Task_RecordBankTitle_Process_NoorMurabaha" targetRef="Task_PickupInspect_Process_NoorMurabaha" />
    <bpmn2:sequenceFlow id="Flow_16_Process_NoorMurabaha" sourceRef="Task_PickupInspect_Process_NoorMurabaha" targetRef="Gateway_QualityCheck_Process_NoorMurabaha" />
    <bpmn2:sequenceFlow id="Flow_17_Process_NoorMurabaha" name="Damaged" sourceRef="Gateway_QualityCheck_Process_NoorMurabaha" targetRef="EndEvent_Dispute_Process_NoorMurabaha" />
    <bpmn2:sequenceFlow id="Flow_18_Process_NoorMurabaha" name="Good" sourceRef="Gateway_QualityCheck_Process_NoorMurabaha" targetRef="Task_ConfirmQabd_Process_NoorMurabaha" />
    <bpmn2:sequenceFlow id="Flow_19_Process_NoorMurabaha" sourceRef="Task_ConfirmQabd_Process_NoorMurabaha" targetRef="Task_DeliverGoods_Process_NoorMurabaha" />
    <bpmn2:sequenceFlow id="Flow_20_Process_NoorMurabaha" sourceRef="Task_DeliverGoods_Process_NoorMurabaha" targetRef="Task_AcceptReceipt_Process_NoorMurabaha" />
    <bpmn2:sequenceFlow id="Flow_21_Process_NoorMurabaha" sourceRef="Task_AcceptReceipt_Process_NoorMurabaha" targetRef="Task_ShowTerms_Process_NoorMurabaha" />
    <bpmn2:sequenceFlow id="Flow_22_Process_NoorMurabaha" sourceRef="Task_ShowTerms_Process_NoorMurabaha" targetRef="Task_GenerateContract_Process_NoorMurabaha" />
    <bpmn2:sequenceFlow id="Flow_23_Process_NoorMurabaha" sourceRef="Task_GenerateContract_Process_NoorMurabaha" targetRef="Task_AuditCompliance_Process_NoorMurabaha" />
