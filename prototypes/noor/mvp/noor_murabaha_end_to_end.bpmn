  <bpmn2:process id="Process_Prescoring" name="ФАЗА 1: Прескоринг" isExecutable="true">
    <bpmn2:documentation>Автоматизированный ежедневный процесс прескоринга, который собирает данные, рассчитывает лимиты и резервирует ликвидность.</bpmn2:documentation>
    <bpmn2:laneSet id="LaneSet_Prescoring">
      <bpmn2:lane id="Lane_ClientApp" name="Customer App">
        <bpmn2:flowNodeRef>EndEvent_LimitDisplayed_Process_Prescoring</bpmn2:flowNodeRef>
      </bpmn2:lane>
      <bpmn2:lane id="Lane_NurBank" name="Nur Bank">
        <bpmn2:flowNodeRef>Task_ReserveLiquidity_Process_Prescoring</bpmn2:flowNodeRef>
      </bpmn2:lane>
      <bpmn2:lane id="Lane_AKSLabs" name="AKSLabs">
        <bpmn2:flowNodeRef>Task_CalculateScore_Process_Prescoring</bpmn2:flowNodeRef>
      </bpmn2:lane>
      <bpmn2:lane id="Lane_0p9vug4" name="Paynet Xolis">
        <bpmn2:flowNodeRef>Task_CollectQRData_Process_Prescoring</bpmn2:flowNodeRef>
      </bpmn2:lane>
      <bpmn2:lane id="Lane_Orchestration" name="Prescoring Orchestration System">
        <bpmn2:flowNodeRef>StartEvent_TimerDaily_Process_Prescoring</bpmn2:flowNodeRef>
      </bpmn2:lane>
    </bpmn2:laneSet>
    <bpmn2:startEvent id="StartEvent_TimerDaily_Process_Prescoring" name="Timer: daily at 00:00">
      <bpmn2:outgoing>Flow_TimerToData_Process_Prescoring</bpmn2:outgoing>
      <bpmn2:timerEventDefinition id="TimerEventDefinition_1w331uc">
        <bpmn2:timeCycle>R/P1D</bpmn2:timeCycle>
      </bpmn2:timerEventDefinition>
    </bpmn2:startEvent>
    <bpmn2:task id="Task_CollectQRData_Process_Prescoring" name="Collect transaction data from QR payments">
      <bpmn2:incoming>Flow_TimerToData_Process_Prescoring</bpmn2:incoming>
      <bpmn2:outgoing>Flow_DataToScore_Process_Prescoring</bpmn2:outgoing>
    </bpmn2:task>
    <bpmn2:task id="Task_CalculateScore_Process_Prescoring" name="Calculate the score and available limit">
      <bpmn2:incoming>Flow_DataToScore_Process_Prescoring</bpmn2:incoming>
      <bpmn2:outgoing>Flow_ScoreToReserve_Process_Prescoring</bpmn2:outgoing>
    </bpmn2:task>
    <bpmn2:task id="Task_ReserveLiquidity_Process_Prescoring" name="Reserve liquidity for the prescoring limit">
      <bpmn2:incoming>Flow_ScoreToReserve_Process_Prescoring</bpmn2:incoming>
      <bpmn2:outgoing>Flow_ReserveToEnd_Process_Prescoring</bpmn2:outgoing>
    </bpmn2:task>
    <bpmn2:endEvent id="EndEvent_LimitDisplayed_Process_Prescoring" name="Limit displayed in the customer app">
      <bpmn2:incoming>Flow_ReserveToEnd_Process_Prescoring</bpmn2:incoming>
    </bpmn2:endEvent>
    <bpmn2:sequenceFlow id="Flow_TimerToData_Process_Prescoring" sourceRef="StartEvent_TimerDaily_Process_Prescoring" targetRef="Task_CollectQRData_Process_Prescoring" />
    <bpmn2:sequenceFlow id="Flow_DataToScore_Process_Prescoring" sourceRef="Task_CollectQRData_Process_Prescoring" targetRef="Task_CalculateScore_Process_Prescoring" />
    <bpmn2:sequenceFlow id="Flow_ScoreToReserve_Process_Prescoring" sourceRef="Task_CalculateScore_Process_Prescoring" targetRef="Task_ReserveLiquidity_Process_Prescoring" />
    <bpmn2:sequenceFlow id="Flow_ReserveToEnd_Process_Prescoring" sourceRef="Task_ReserveLiquidity_Process_Prescoring" targetRef="EndEvent_LimitDisplayed_Process_Prescoring" />
  </bpmn2:process>
