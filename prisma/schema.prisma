generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  TOP_MANAGER
  PMO
  PROJECT_MANAGER
  TEAM_MEMBER
  VIEWER
}

enum ProjectStatus {
  COMPLETED
  IN_PROGRESS
  PLANNED
  PAUSED
}

enum TaskStatus {
  BACKLOG
  IN_PROGRESS
  REVIEW
  DONE
  BLOCKED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id         String   @id @default(cuid())
  name       String
  shortName  String
  email      String   @unique
  role       Role     @default(TEAM_MEMBER)
  avatarColor String  @default("#2563EB")
  stack      String?
  grade      String?
  hireDate   DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  managedProjects  Project[]        @relation("ProjectManager")
  taskAssignees    TaskAssignee[]
  workloadRecords  WorkloadRecord[]
  projectUpdates   ProjectUpdate[]
  activityLogs     ActivityLog[]
  teamMemberships  TeamMember[]
}

model Department {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique
  color     String   @default("#2563EB")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users    User[]
  projects Project[]
}

model Project {
  id          String        @id @default(cuid())
  externalId  String?       @unique
  name        String
  product     String
  goal        String?
  basis       String?
  status      ProjectStatus @default(PLANNED)
  priority    Priority      @default(MEDIUM)
  riskLevel   RiskLevel     @default(LOW)
  progress    Int           @default(0)
  startDate   DateTime?
  endDate     DateTime?
  budget      String?
  customer    String?
  supplier    String?
  demoReady   Boolean       @default(false)
  jiraEpicKey String?
  origin      String?       @default("Manual")
  info        String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  managerId String?
  manager   User?   @relation("ProjectManager", fields: [managerId], references: [id])

  tasks          Task[]
  updates        ProjectUpdate[]
  workloadItems  WorkloadRecord[]
  activityLogs   ActivityLog[]
  teamMembers    TeamMember[]
}

model TeamMember {
  projectId String
  userId    String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
}

model Task {
  id          String     @id @default(cuid())
  title       String
  description String?
  status      TaskStatus @default(BACKLOG)
  priority    Priority   @default(MEDIUM)
  dueDate     DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  assignees TaskAssignee[]
}

model TaskAssignee {
  taskId String
  userId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
}

model ProjectUpdate {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  authorId String?
  author   User?   @relation(fields: [authorId], references: [id])
}

model WorkloadRecord {
  id         String  @id @default(cuid())
  allocation Int     @default(100) // percentage 0–100

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([projectId, userId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String
  data      Json?
  createdAt DateTime @default(now())

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])

  userId String?
  user   User?   @relation(fields: [userId], references: [id])
}
